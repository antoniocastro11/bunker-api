generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model Idea {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  ideaType    IdeaType?
  status      Status?
  createdAt   DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

enum IdeaType {
  WebApp
  MobileApp
  Game
  Automation
}

enum Status {
  Completed
  InProgress
  Stopped
}


model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  ideas Idea[]
  refreshToken String?
}